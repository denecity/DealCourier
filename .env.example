# Copy this to .env and fill in your secrets.
# Environment variables here OVERRIDE the values in config.yaml.

# ─── AI backend (any OpenAI-compatible provider) ───────────────────────────
# Examples:
#   OpenAI:      API_KEY=sk-...        BASE_URL=https://api.openai.com/v1
#   OpenRouter:  API_KEY=sk-or-...     BASE_URL=https://openrouter.ai/api/v1
#   DeepSeek:    API_KEY=sk-...        BASE_URL=https://api.deepseek.com/v1
API_KEY=
BASE_URL=https://openrouter.ai/api/v1

# ─── Discord notifications (optional) ─────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ─── Server overrides (optional) ───────────────────────────────────────────
# DEALCOURIER_HOST=127.0.0.1
# DEALCOURIER_PORT=8000
# DEALCOURIER_DB=data/dealcourier.db
